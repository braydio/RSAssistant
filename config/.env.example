# RSAssistant sample configuration
# Copy to config/.env and fill in your values.
# To use a different file, set ENV_FILE=/absolute/or/relative/path.env in the process environment.

# -----------------------------------------------------------------------------
# Core Discord/runtime
# -----------------------------------------------------------------------------
ENV_FILE=
VOLUMES_DIR=
BOT_TOKEN=
BOT_PREFIX=..
DISCORD_PRIMARY_CHANNEL=
DISCORD_SECONDARY_CHANNEL=
DISCORD_TERTIARY_CHANNEL=
DISCORD_HOLDINGS_CHANNEL=
DISCORD_WATCHLIST_CHANNEL=
ENABLED_PLUGINS=

PROGRAMMATIC_POLICY_ENABLED=true
AUTO_RSA_HOLDINGS_ENABLED=true
AUTO_RSA_HOLDINGS_FILE=volumes/db/auto_rsa_holdings.json
RSA_COMMAND_MIN_INTERVAL_SECONDS=2
ENABLE_MARKET_REFRESH=false
AUTO_REFRESH_ON_REMINDER=false
HOLDING_ALERT_MIN_PRICE=1
AUTO_SELL_LIVE=false
AUTO_BUY_WATCHLIST=false
HISTORY_QUERY_ENABLED=false
ENABLE_TICKER=false

CSV_LOGGING_ENABLED=true
EXCEL_LOGGING_ENABLED=true
SQL_LOGGING_ENABLED=true
LOG_LEVEL=INFO
LOG_FILE=volumes/logs/rsassistant.log
LOG_BACKUP_COUNT=2
ENV=production
HEARTBEAT_ENABLED=true
HEARTBEAT_PATH=volumes/logs/heartbeat.txt
HEARTBEAT_INTERVAL=60

IGNORE_TICKERS=
IGNORE_BROKERS=
IGNORE_TICKERS_FILE=config/ignore_tickers.txt
IGNORE_BROKERS_FILE=config/ignore_brokers.txt
TAGGED_ALERTS_FILE=config/tagged_alerts.txt
MARKET_HOLIDAYS_FILE=config/market_holidays.txt
AUTOBUY_CONFIG_FILE=config/autobuy_overrides.json
TAGGED_ALERT_TICKERS=

MENTION_ON_ALERTS=false
MENTION_USER_IDS=
MENTION_USER_ID=
MY_ID=

# -----------------------------------------------------------------------------
# OpenAI/LLM
# -----------------------------------------------------------------------------
OPENAI_POLICY_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# SEC request identity
# -----------------------------------------------------------------------------
SEC_REQUEST_USER_AGENT=RSAssistant/3.1 (ops@example.com)
SEC_USER_AGENT=
SEC_REQUEST_FROM=ops@example.com
SEC_FROM=

# -----------------------------------------------------------------------------
# Plugin loading (ENABLED_PLUGINS)
# -----------------------------------------------------------------------------
# Comma-separated plugin identifiers, e.g. ENABLED_PLUGINS=ultma
# Plugin-specific keys also belong in this same config/.env file.

# -----------------------------------------------------------------------------
# ULT-MA trading/API keys
# -----------------------------------------------------------------------------
# Keep ULT-MA values in config/.env (or ENV_FILE).
# Optional key namespacing is supported for trading/API keys (e.g., TRADING_* and AUTO_RSA_*).
ENABLE_AUTOMATED_TRADING=false
TRADING_ALLOW_EXTENDED_TREND=false
TRADING_TREND_SAFEGUARD_ENABLED=true
TRADING_LOGGING_ENABLED=true
TRADING_TRAILING_BUFFER=0.03
TRADING_PRICE_CHECK_INTERVAL_SECONDS=300
TRADING_BROKERS=

# AUTO_RSA does not expose an API URL/key in the standard RSAssistant flow.
# Leave these blank unless you intentionally run a separate API bridge.
AUTO_RSA_BASE_URL=
AUTO_RSA_API_KEY=
