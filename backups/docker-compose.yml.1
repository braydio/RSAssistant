services:
  rsassistant:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: RSAssistant
    env_file:
      - /home/braydenchaffee/mnt/windows-share/Docker/Volumes/config/.env  # config/ is in the root directory
    volumes:
      - /home/braydenchaffee/mnt/windows-share/Docker/Volumes/logs:/app/volumes/logs   # Persist logs
      - /home/braydenchaffee/mnt/windows-share/Docker/Volumes/db:/app/volumes/db       # Persist database
      - /home/braydenchaffee/mnt/windows-share/Docker/Volumes/excel:/app/volumes/excel # Persist Excel
      - /home/braydenchaffee/mnt/windows-share/Docker/Volumes/config:/app/config       # Shared config files
      - /home/braydenchaffee/Projects/RSAssistant/RSViewer/logs:/app/volumes/logs      # Locally saved logs (for RSView.py)
      - /home/braydenchaffee/Projects/RSAssistant/RSViewer/config:/app/volumes/config  # Locally saved config (for RSView.py)
    environment:
      ENVIRONMENT: production
      TZ: America/New_York
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "1.0"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  db:
    image: postgres:14
    container_name: postgres_db
    environment:
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
      POSTGRES_DB: reverse_splits
    volumes:
      - db_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"

volumes:
  db_data:
